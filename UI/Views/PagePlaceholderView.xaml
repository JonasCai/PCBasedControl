<UserControl x:Class="UI.Views.PagePlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Views"
             mc:Ignorable="d">
    <Grid>
        <Border Background="{StaticResource Brush.CardBackground}"
                BorderBrush="{StaticResource Brush.CardBorder}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}" />
                    <TextBlock Text="{Binding Description}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="主工作区"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBlock Text="这里放置当前页面的核心内容，例如工艺流程、自动化传输、报警列表、趋势图等。"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#FFFFFF"
                            BorderBrush="{StaticResource Brush.CardBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="辅助信息区"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <TextBlock Text="这里可放状态摘要、步骤导航、操作区、批次信息或右侧详情。"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
