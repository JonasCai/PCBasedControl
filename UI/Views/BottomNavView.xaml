<UserControl x:Class="UI.Views.BottomNavView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Views"
             xmlns:conv="clr-namespace:UI.Converters"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:UI.ViewModels">

    <UserControl.Resources>
        <conv:BottomNavItemClickParameterConverter x:Key="BottomNavItemClickParameterConverter" />
    </UserControl.Resources>

    <Border Background="Transparent"
            BorderBrush="{StaticResource Brush.BottomNavBorder}"
            BorderThickness="0"
            Padding="0">
        
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Focusable="False">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BottomNavGroupViewModel}">
                        <Grid Height="72" Margin="2,0">
                            <Grid.Resources>
                                <Style TargetType="Border" x:Key="StandaloneVisibilityBorderStyle">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasItems}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>

                                <Style TargetType="Border" x:Key="CompositeVisibilityBorderStyle">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasItems}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Resources>

                            <!-- 单项组 -->
                            <Border Style="{StaticResource StandaloneVisibilityBorderStyle}" Width="110" Margin="0 0 10 0">
                                <Button Style="{StaticResource BottomStandaloneGroupButtonStyle}"
                                        Command="{Binding DataContext.NavigateGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                 Width="28"
                                                                 Height="28"
                                                                 HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Title}"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Border>

                            <!-- 复合组 -->
                            <Border Style="{StaticResource CompositeVisibilityBorderStyle}" 
                                    Margin="0 0 10 0" BorderThickness="0"
                                    Background="{StaticResource Brush.BottomGroupBackground2}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 一级组头 -->
                                    <Button Grid.Column="0" Width="110"
                                            Style="{StaticResource BottomGroupHeaderButtonStyle}"
                                            Command="{Binding DataContext.NavigateGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="{Binding IconKind}"
                                                                     Width="28"
                                                                     Height="28"
                                                                     HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Title}"
                                                       Margin="0,4,0,0"
                                                       HorizontalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>

                                    <materialDesign:PackIcon Grid.Column="1" Kind="ChevronLeft"
                                        Width="20" Foreground="{StaticResource Brush.BottomNavText}"
                                        Height="20" VerticalAlignment="Center"
                                        HorizontalAlignment="Center" />
                                    
                                    <!-- 二级项 -->
                                    <ItemsControl Grid.Column="2"
                                                  ItemsSource="{Binding Items}"
                                                  Tag="{Binding}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:BottomNavItemViewModel}">
                                                <Button Style="{StaticResource BottomSubItemButtonStyle}"
                                                        Width="90">
                                                    <Button.Command>
                                                        <Binding Path="DataContext.NavigateItemCommand"
                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </Button.Command>
                                                    <Button.CommandParameter>
                                                        <MultiBinding Converter="{StaticResource BottomNavItemClickParameterConverter}">
                                                            <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="Tag" />
                                                            <Binding />
                                                        </MultiBinding>
                                                    </Button.CommandParameter>

                                                    <TextBlock Text="{Binding Title}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Border>
</UserControl>
