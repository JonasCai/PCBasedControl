<UserControl x:Class="UI.Recipe.RecipeEditorView" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Recipe" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <SolidColorBrush x:Key="Brush.PageBackground" Color="#F4F6F8"/>
        <SolidColorBrush x:Key="Brush.TopBarBackground" Color="#1E5FAF"/>
        <SolidColorBrush x:Key="Brush.CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Brush.CardBorder" Color="#D9E0E8"/>
        <SolidColorBrush x:Key="Brush.TextPrimary" Color="#1F2937"/>
        <SolidColorBrush x:Key="Brush.TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="Brush.Accent" Color="#2D7FF9"/>
        <SolidColorBrush x:Key="Brush.SelectedBg" Color="#EAF3FF"/>
        <SolidColorBrush x:Key="Brush.SelectedBorder" Color="#7AAEFF"/>
        <SolidColorBrush x:Key="Brush.TopButtonBorder" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="Brush.TopButtonIcon" Color="#3949AB"/>
        <SolidColorBrush x:Key="Brush.TopButtonFont" Color="#424242"/>
        <SolidColorBrush x:Key="Brush.Separator" Color="#E5E5E5"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.TopButtonBorder}"/>
        </Style>

        <Style x:Key="PrimaryToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0"/>
            <Setter Property="Background" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.TopButtonBorder}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Height" Value="42"/>
        </Style>

        <DataTemplate x:Key="StepInsertMenuItemTemplate" DataType="{x:Type local:StepInsertMenuItemViewModel}">
            <StackPanel Orientation="Horizontal">
                <Border Width="18"
                    Height="18"
                    CornerRadius="4"
                    Background="{Binding ColorBrush}"
                    VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="{Binding IconKind}"
                                         Width="12"
                                         Height="12"
                                         Foreground="White"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding Header}"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <ContextMenu x:Key="StepNodeContextMenu"
                 DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">

            <MenuItem Header="前插步骤"
                  ItemsSource="{Binding PlacementTarget.Tag.InsertBeforeMenuItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="ArrowUpBoldBoxOutline" Width="18" Height="18"/>
                </MenuItem.Icon>
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding}" />
                        <Setter Property="HeaderTemplate" Value="{StaticResource StepInsertMenuItemTemplate}" />
                        <Setter Property="Command" Value="{Binding ExecuteCommand}" />
                        <Setter Property="CommandParameter" Value="{Binding}" />
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <MenuItem Header="后插步骤"
                  ItemsSource="{Binding PlacementTarget.Tag.InsertAfterMenuItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="ArrowDownBoldBoxOutline" Width="18" Height="18"/>
                </MenuItem.Icon>
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding}" />
                        <Setter Property="HeaderTemplate" Value="{StaticResource StepInsertMenuItemTemplate}" />
                        <Setter Property="Command" Value="{Binding ExecuteCommand}" />
                        <Setter Property="CommandParameter" Value="{Binding}" />
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <MenuItem Header="插入子步骤"
                  Visibility="{Binding IsCycle, Converter={StaticResource BoolToVisibilityConverter}}"
                  ItemsSource="{Binding PlacementTarget.Tag.InsertChildMenuItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="PlaylistPlus" Width="18" Height="18"/>
                </MenuItem.Icon>
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Header" Value="{Binding}" />
                        <Setter Property="HeaderTemplate" Value="{StaticResource StepInsertMenuItemTemplate}" />
                        <Setter Property="Command" Value="{Binding ExecuteCommand}" />
                        <Setter Property="CommandParameter" Value="{Binding}" />
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>

            <Separator/>

            <MenuItem Header="上移"
                  Command="{Binding PlacementTarget.Tag.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="ChevronUp" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="下移"
                  Command="{Binding PlacementTarget.Tag.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="ChevronDown" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem Header="展开"
                  Command="{Binding PlacementTarget.Tag.ExpandSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="UnfoldMoreHorizontal" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="折叠"
                  Command="{Binding PlacementTarget.Tag.CollapseSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="UnfoldLessHorizontal" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>

            <Separator/>

            <MenuItem Header="删除"
                  Command="{Binding PlacementTarget.Tag.DeleteStepCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <HierarchicalDataTemplate x:Key="StepTreeItemTemplate"
                              DataType="{x:Type local:RecipeStepNodeViewModel}"
                              ItemsSource="{Binding Children}">
            <Border x:Name="NodeBorder"
                Margin="0,0,10,8"
                Padding="5"
                CornerRadius="10"
                Background="#FAFBFC"
                BorderBrush="#DCE3EA"
                BorderThickness="1"
                HorizontalAlignment="Right"
                Width="440"
                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                ContextMenu="{StaticResource StepNodeContextMenu}"
                PreviewMouseRightButtonDown="NodeBorder_PreviewMouseRightButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="28"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="40"
                        Height="24"
                        CornerRadius="6"
                        Background="#EEF2F7">
                        <TextBlock Text="{Binding DisplayIndex}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="#475569"/>
                    </Border>

                    <Border Grid.Column="1"
                        Width="22"
                        Height="22"
                        CornerRadius="4"
                        Background="{Binding TypeColorBrush}">
                        <materialDesign:PackIcon Kind="{Binding IconKind}"
                            Width="16"
                            Height="16"
                            Foreground="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,10,0">
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource Brush.TextPrimary}"
                            FontSize="12"/>

                        <TextBlock Text="{Binding Summary}"  VerticalAlignment="Center"
                            Foreground="{StaticResource Brush.TextSecondary}"
                            FontSize="12"
                            Margin="15,0,0,0"/>
                    </StackPanel>

                    <materialDesign:PackIcon Grid.Column="3"
                        Kind="ChevronRight"
                        Width="18"
                        Height="18"
                        Foreground="#94A3B8"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="NodeBorder" Property="Background" Value="{StaticResource Brush.SelectedBg}" />
                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="{StaticResource Brush.SelectedBorder}" />
                </DataTrigger>

                <DataTrigger Binding="{Binding Level}" Value="1">
                    <Setter TargetName="NodeBorder" Property="Width" Value="410" />
                </DataTrigger>

                <DataTrigger Binding="{Binding Level}" Value="2">
                    <Setter TargetName="NodeBorder" Property="Width" Value="380" />
                </DataTrigger>

                <DataTrigger Binding="{Binding Level}" Value="3">
                    <Setter TargetName="NodeBorder" Property="Width" Value="350" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="LibraryItemTemplate" DataType="{x:Type local:StepLibraryItemViewModel}">
            <Border Margin="0,0,0,6"
                Padding="10 8"
                CornerRadius="6"
                Background="#FAFBFC"
                BorderBrush="#DCE3EA"
                BorderThickness="1"
                Cursor="Hand"
                PreviewMouseMove="LibraryItem_PreviewMouseMove">
                <StackPanel Orientation="Horizontal">
                    <Border Width="18" Height="18" CornerRadius="4" Background="{Binding TypeColorBrush}">
                        <materialDesign:PackIcon Kind="{Binding IconKind}"
                                             Width="12"
                                             Height="12"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding DisplayName}"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PulseEditorTemplate">
            <StackPanel>
                <TextBlock Text="Pulse" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Target Reactant" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PulseTargetReactant, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Pulse Time (ms)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PulseTimeMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Carrier Gas Flow (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PulseCarrierGasFlowSccm, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PurgeEditorTemplate">
            <StackPanel>
                <TextBlock Text="Purge" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Duration (ms)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PurgeDurationMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Purge Gas Flow (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PurgeGasFlowSccm, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="WaitEditorTemplate">
            <StackPanel>
                <TextBlock Text="Wait" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Duration (ms)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitDurationMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="MoveAxisEditorTemplate">
            <StackPanel>
                <TextBlock Text="Move Axis" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Target Axis" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding MoveAxisTargetAxis, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Target Position" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding MoveAxisTargetPosition, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Target Velocity" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding MoveAxisTargetVelocity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SetPressureEditorTemplate">
            <StackPanel>
                <TextBlock Text="Set Pressure" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Target Pressure (Pa)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding SetPressureTargetPa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Tolerance (Pa)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding SetPressureTolerancePa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="WaitPressureStableEditorTemplate">
            <StackPanel>
                <TextBlock Text="Wait Pressure Stable" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Timeout (s)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitPressureTimeoutSec, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Stable Duration (s)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitPressureStableDurationSec, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Target Pressure (Pa)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitPressureTargetPa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Tolerance (Pa)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitPressureTolerancePa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SetTemperatureEditorTemplate">
            <StackPanel>
                <TextBlock Text="Set Temperature" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Target Temperature (°C)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding SetTemperatureTargetC, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Tolerance (°C)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding SetTemperatureToleranceC, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="WaitTemperatureStableEditorTemplate">
            <StackPanel>
                <TextBlock Text="Wait Temperature Stable" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Timeout (s)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitTemperatureTimeoutSec, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Stable Duration (s)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitTemperatureStableDurationSec, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Target Temperature (°C)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitTemperatureTargetC, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Tolerance (°C)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding WaitTemperatureToleranceC, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PumpDownEditorTemplate">
            <StackPanel>
                <TextBlock Text="Pump Down" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Target Pressure (Pa)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PumpDownTargetPressurePa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Timeout (s)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding PumpDownTimeoutSec, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="VentEditorTemplate">
            <StackPanel>
                <TextBlock Text="Vent" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Target Pressure (Pa)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding VentTargetPressurePa, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Timeout (s)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding VentTimeoutSec, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ReactionZoneEditorTemplate">
            <StackPanel>
                <TextBlock Text="Reaction Zone" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Carrier Gas A (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding ReactionCarrierGasA, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Dilution Gas A (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding ReactionDilutionGasA, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Carrier Gas B (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding ReactionCarrierGasB, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Dilution Gas B (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding ReactionDilutionGasB, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <TextBlock Text="Isolation Gas (sccm)" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding ReactionIsolationGas, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CycleEditorTemplate">
            <StackPanel>
                <TextBlock Text="Cycle" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>
                <TextBlock Text="Loop Count" Style="{StaticResource EditorLabelStyle}"/>
                <TextBox Text="{Binding CycleLoopCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}"/>
                <Border Padding="12" CornerRadius="10" BorderBrush="#DCE3EA" BorderThickness="1" Background="#FAFBFC">
                    <StackPanel>
                        <TextBlock Text="子步骤信息" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Margin="0,8,0,0" Text="{Binding Summary}" Foreground="{StaticResource Brush.TextSecondary}"/>
                        <TextBlock Margin="0,8,0,0"
                               Text="可在左侧树中展开 Cycle，并通过拖拽或“添加子步骤”维护内部步骤。"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.TextSecondary}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="NoSelectionTemplate">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ClipboardEditOutline" Width="56" Height="56" Foreground="#A0AEC0" HorizontalAlignment="Center"/>
                    <TextBlock Text="请选择一个步骤" FontSize="22" FontWeight="SemiBold" Margin="0,14,0,6" HorizontalAlignment="Center"/>
                    <TextBlock Text="左侧选择配方步，或从右侧步骤库拖入。" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <local:StepEditorTemplateSelector x:Key="StepEditorTemplateSelector"
                                   PulseTemplate="{StaticResource PulseEditorTemplate}"
                                   PurgeTemplate="{StaticResource PurgeEditorTemplate}"
                                   WaitTemplate="{StaticResource WaitEditorTemplate}"
                                   MoveAxisTemplate="{StaticResource MoveAxisEditorTemplate}"
                                   ReactionZoneTemplate="{StaticResource ReactionZoneEditorTemplate}"
                                   PumpDownTemplate="{StaticResource PumpDownEditorTemplate}"
                                   VentTemplate="{StaticResource VentEditorTemplate}"
                                   SetPressureTemplate="{StaticResource SetPressureEditorTemplate}"
                                   WaitPressureStableTemplate="{StaticResource WaitPressureStableEditorTemplate}"
                                   SetTemperatureTemplate="{StaticResource SetTemperatureEditorTemplate}"
                                   WaitTemperatureStableTemplate="{StaticResource WaitTemperatureStableEditorTemplate}"
                                   CycleTemplate="{StaticResource CycleEditorTemplate}"
                                   EmptyTemplate="{StaticResource NoSelectionTemplate}"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.PageBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{StaticResource PrimaryToolbarButtonStyle}" Command="{Binding NewRecipeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                        <TextBlock Text="新建" FontSize="12" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ValidateRecipeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="16" Height="16" Foreground="{StaticResource Brush.TopButtonIcon}"/>
                        <TextBlock Text="检测" FontSize="12" Margin="8,0,0,0" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SaveRecipeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" Foreground="{StaticResource Brush.TopButtonIcon}"/>
                        <TextBlock Text="保存" FontSize="12" Margin="8,0,0,0" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SaveAsRecipeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSaveEditOutline" Width="16" Height="16" Foreground="{StaticResource Brush.TopButtonIcon}"/>
                        <TextBlock Text="另存为" FontSize="12" Margin="8,0,0,0" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding OpenRecipeCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Import" Width="18" Height="18" Foreground="{StaticResource Brush.TopButtonIcon}"/>
                        <TextBlock Text="导入" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="5" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ExportJsonCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Export" Width="16" Height="16" Foreground="{StaticResource Brush.TopButtonIcon}"/>
                        <TextBlock Text="导出" FontSize="12" Margin="8,0,0,0" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </StackPanel>
                </Button>


                <StackPanel Grid.Column="6" HorizontalAlignment="Right" Orientation="Horizontal">

                    <Button Width="50" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                        materialDesign:ButtonAssist.CornerRadius="10 0 0 10"  
                        Command="{Binding UploadRecipeCommand}">
                        <materialDesign:PackIcon Kind="Download" Width="20" Height="20" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </Button>

                    <Button Width="50" Style="{StaticResource ToolbarButtonStyle}" Margin="0 0 5 0"
                        materialDesign:ButtonAssist.CornerRadius="0 10 10 0"  
                        Command="{Binding DownloadRecipeCommand}">
                        <materialDesign:PackIcon Kind="Upload" Width="20" Height="20" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </Button>


                    <Button Width="50" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                        materialDesign:ButtonAssist.CornerRadius="10" 
                        Command="{Binding DownloadRecipeCommand}">
                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="{StaticResource Brush.TopButtonFont}"/>
                    </Button>
                </StackPanel>


            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="520"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="配方列表" VerticalAlignment="Center" FontSize="14" Style="{StaticResource SectionTitleStyle}"/>
                    <Separator Grid.Row="1" Background="{StaticResource Brush.Separator}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding RecipeName}" VerticalAlignment="Center" FontSize="18" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Margin="20 0 0 0" Padding="15 8" Background="#EAF3FF" CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ModeEdit" Height="16" Width="16" Foreground="{StaticResource Brush.Accent}"/>
                                <TextBlock Text="{Binding Mode}" VerticalAlignment="Center"
                                Foreground="{StaticResource Brush.Accent}"
                                FontSize="12" Margin="5 0 0 0"
                                FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                           Margin="0,14,0,10"
                           Text="{Binding StepCountText}"
                           Style="{StaticResource HintTextStyle}"/>

                    <TreeView Grid.Row="2" Padding="0 0 10 0"
                          x:Name="StepTreeView"
                          Background="Transparent"
                          BorderThickness="0"
                          AllowDrop="True"
                          PreviewDragOver="StepTreeView_PreviewDragOver"
                          Drop="StepTreeView_Drop"
                          ItemsSource="{Binding RootSteps}"
                          SelectedItemChanged="StepTreeView_SelectedItemChanged"
                          ItemTemplate="{StaticResource StepTreeItemTemplate}">
                        <TreeView.Resources>
                            <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid Width="16" Height="16" Background="Transparent">
                                                <Path x:Name="Arrow"
                                                    Data="M 0 0 L 8 8 L 0 16 Z"
                                                    Fill="#6B7280"
                                                    Stretch="Uniform"
                                                    Width="8"
                                                    Height="8"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" CenterX="4" CenterY="4"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <ToggleButton x:Name="Expander"
                                  Grid.Row="0"
                                  Grid.Column="0"
                                  Width="16"
                                  Height="16"
                                  Margin="0,10,6,0"
                                  ClickMode="Press"
                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                  Style="{StaticResource ExpandCollapseToggleStyle}"/>

                                                <Border x:Name="ItemChrome"
                            Grid.Row="0"
                            Grid.Column="1"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            SnapsToDevicePixels="True">
                                                    <ContentPresenter x:Name="PART_Header"
                                          ContentSource="Header"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                </Border>

                                                <ItemsPresenter x:Name="ItemsHost"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,0,0"/>
                                            </Grid>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                </Trigger>

                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                </Trigger>

                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
                                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>

                                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                    <Setter TargetName="ItemChrome" Property="Background" Value="Transparent"/>
                                                    <Setter TargetName="ItemChrome" Property="BorderBrush" Value="Transparent"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>
                    </TreeView>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}" CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="配方步参数编辑" VerticalAlignment="Center" FontSize="14" Style="{StaticResource SectionTitleStyle}"/>

                    <ContentControl Grid.Row="1"
                                Margin="0,16,0,0"
                                Content="{Binding SelectedNode}"
                                ContentTemplateSelector="{StaticResource StepEditorTemplateSelector}"/>
                </Grid>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource CardBorderStyle}" CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="配方步库" FontSize="14" VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}"/>

                    <ScrollViewer Grid.Row="2" Margin="0 16 0 0"
                              VerticalScrollBarVisibility="Auto"
                              materialDesign:ScrollViewerAssist.PaddingMode="Default">
                        <ItemsControl Padding="0 0 20 0"
                        ItemsSource="{Binding FilteredLibrarySteps}"
                        ItemTemplate="{StaticResource LibraryItemTemplate}"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl> 
